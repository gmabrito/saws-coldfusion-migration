{
  "_comment": "PoC: All routes require Azure AD authentication. No anonymous access. Post-PoC: add /public/* and /api/public/* exceptions for citizen-facing TPIA submission pages on SAWS.org.",
  "routes": [
    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 }
  },
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Content-Security-Policy": "default-src 'self'; connect-src 'self' https://*.saws.org; style-src 'self' 'unsafe-inline'; script-src 'self'"
  },
  "navigationFallback": { "rewrite": "/index.html" }
}

{
  "_comment": "Template for apps with both public (SAWS.org) and internal (SAWS employee) pages. Public routes allow anonymous. Internal routes require Azure AD. API routes mirrored: /api/public/* anonymous, /api/internal/* authenticated at Express layer.",
  "routes": [
    { "route": "/public/*", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/public/*", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 }
  },
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Content-Security-Policy": "default-src 'self'; connect-src 'self' https://*.saws.org; style-src 'self' 'unsafe-inline'; script-src 'self'"
  },
  "navigationFallback": { "rewrite": "/index.html" }
}
